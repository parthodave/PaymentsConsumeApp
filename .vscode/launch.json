{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chrome (Angular)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "npm: start",
      "sourceMaps": true,
      "runtimeArgs": ["--remote-debugging-port=9222"],
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/src/*",
        "webpack:///./src/*": "${webRoot}/src/*",
        "webpack:///*": "${webRoot}/*",
        "webpack:///./*": "${webRoot}/*"
      }
    },
    {
      "name": "Attach to Chrome",
      "type": "pwa-chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Serve + Chrome",
      "configurations": ["Launch Chrome (Angular)"]
    }
  ]
}
